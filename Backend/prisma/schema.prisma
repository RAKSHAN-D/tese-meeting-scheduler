generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Attendee {
  id        Int       @id @default(autoincrement())
  firstName String
  lastName  String
  email     String    @unique
  createdAt DateTime  @default(now())
  bookings  Booking[]

  @@map("attendees")
}

model TimeSlot {
  id        Int       @id @default(autoincrement())
  slotDate  DateTime  @db.Date
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  booking   Booking?

  @@unique([slotDate, startAt])
  @@map("time_slots")
}

model Booking {
  id          Int       @id @default(autoincrement())
  attendeeId  Int
  timeSlotId  Int       @unique
  status      BookingStatus @default(CONFIRMED)
  timezone    String
  meetLink    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  attendee    Attendee  @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  timeSlot    TimeSlot  @relation(fields: [timeSlotId], references: [id], onDelete: Restrict)
  email       Email?

  @@index([attendeeId])
  @@map("bookings")
}

model Email {
  id         Int         @id @default(autoincrement())
  bookingId  Int         @unique
  status     EmailStatus @default(PENDING)
  attemptCount Int       @default(0)
  toEmail    String
  subject    String
  providerMessageId String?
  lastError  String?
  lastAttemptAt DateTime?
  sentAt     DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  booking    Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("emails")
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  RESCHEDULED
}
